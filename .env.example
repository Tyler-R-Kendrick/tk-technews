# Optional: reserved for a later LLM-backed summarization pass.
# OPENAI_API_KEY=
# Optional: use Vercel AI Gateway with the AI SDK.
# AI_GATEWAY_API_KEY=
# Optional: inference routing for durable source pipeline.
# TK_TECHNEWS_INFERENCE_PROVIDER=auto
# TK_TECHNEWS_MODEL=gpt-5.4-mini
# TK_TECHNEWS_CODEX_MODEL=gpt-5.4
# TK_TECHNEWS_COPILOT_MODEL=gpt-5

# Optional: enables Firecrawl MCP and Firecrawl-backed scraping for dynamic pages.
# Get a key from Firecrawl, then restart the agent/dev shell after setting it.
# FIRECRAWL_API_KEY=

# YouTube Data API v3 MCP server.
# YOUTUBE_API_KEY=

# Optional: OAuth 2.0 bearer token for captions.list/download and mine=true calls.
# YOUTUBE_OAUTH_TOKEN=
