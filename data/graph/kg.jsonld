      "@id": "source-doc:abc4d40cb8d2ba2a07cc",
      "@type": "SourceDocument",
      "sourceSummaryId": "publicationfeeds-marktechpost-https-www-marktechpost-com-p-79982",
      "canonicalUri": "https://www.marktechpost.com/2026/05/20/nvidia-ai-releases-nemotron-labs-diffusion-a-tri-mode-language-model-with-6x-tokens-per-forward-over-qwen3-8b/",
      "status": "parsed",
      "title": "NVIDIA AI Releases Nemotron-Labs-Diffusion: A Tri-Mode Language Model with 6× Tokens Per Forward Over Qwen3-8B",
      "sourceName": "MarkTechPost",
      "sourceKind": "publicationFeeds",
      "publishedAt": "2026-05-20T10:41:02.000Z",
      "observedAt": "2026-05-20T18:26:24.285Z",
      "ingestedAt": "2026-05-20T18:40:29.441Z",
      "contentHash": "18ed9cb147341cc7216fa1c5e484deb4",
      "tags": [
        "ai",
        "publications",
        "publicationfeeds",
        "agentic ai",
        "ai infrastructure",
        "ai paper summary",
        "ai shorts",
        "applications",
        "artificial intelligence",
        "editors pick"
      ],
      "textSpans": [
        {
          "id": "source-doc:abc4d40cb8d2ba2a07cc:span-1",
          "type": "TextSpan",
          "text": "NVIDIA researchers have released Nemotron-Labs-Diffusion, a language model family that unifies three decoding modes in one architecture. The model supports autoregressive (AR) decoding, diffusion-based parallel decoding, and self-speculation decoding.",
          "startOffset": 0,
          "endOffset": 251,
          "citation": {
            "title": "NVIDIA AI Releases Nemotron-Labs-Diffusion: A Tri-Mode Language Model with 6× Tokens Per Forward Over Qwen3-8B",
            "source": "MarkTechPost",
            "url": "https://www.marktechpost.com/2026/05/20/nvidia-ai-releases-nemotron-labs-diffusion-a-tri-mode-language-model-with-6x-tokens-per-forward-over-qwen3-8b/"
          }
        }
      ],
