    {
      "@id": "source-doc:e7713be25757d91286a1",
      "@type": "SourceDocument",
      "sourceSummaryId": "twitterfeeds-twitter-googleai-https-twitter-com-googleai-status-2057128296538861943",
      "canonicalUri": "https://x.com/GoogleAI/status/2057128296538861943",
      "status": "parsed",
      "title": "We partnered with artists, designers, and builders to create new AI tools that solve real problems in their creative workflows. Here’s what’s new: ...",
      "sourceName": "@GoogleAI",
      "sourceKind": "twitterFeeds",
      "publishedAt": "2026-05-20T15:56:20.000Z",
      "observedAt": "2026-05-20T18:26:24.285Z",
      "ingestedAt": "2026-05-20T18:40:29.441Z",
      "contentHash": "b03d9eb386ffa324e2b53472904ed32a",
      "tags": [
        "ai",
        "twitter",
        "twitterfeeds"
      ],
      "textSpans": [
        {
          "id": "source-doc:e7713be25757d91286a1:span-1",
          "type": "TextSpan",
          "text": "We partnered with artists, designers, and builders to create new AI tools that solve real problems in their creative workflows.Here’s what’s new:— Introducing Google Pics in @GoogleWorkspace: A brand-new image creation & editing tool. Move and resize objects, add text, and translate just by hovering and clicking— Big updates to @GoogleFlow: 1) You can now create with Gemini Omni Flash in Google Flow 2) Google Flow Agent is a multi-step creative partner that reasons and plans complex tasks with you.",
          "startOffset": 0,
