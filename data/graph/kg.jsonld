      "@id": "source-doc:60f4a726e1ce98c8cecd",
      "@type": "SourceDocument",
      "sourceSummaryId": "twitterfeeds-twitter-omarsar0-https-twitter-com-omarsar0-status-2057146084728664360",
      "canonicalUri": "https://x.com/omarsar0/status/2057146084728664360",
      "status": "parsed",
      "title": "RT elvis: Self-improving AI is a big deal! As a first step, I've been exploring how much of the post-training can be automated. Here is a first post o...",
      "sourceName": "@omarsar0",
      "sourceKind": "twitterFeeds",
      "publishedAt": "2026-05-20T15:20:37.000Z",
