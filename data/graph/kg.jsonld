        "announcements",
        "vercelannouncements"
      ],
      "textSpans": [
        {
          "id": "source-doc:7e5ed137447eef1cc390:span-1",
          "type": "TextSpan",
          "text": "Grok Build 0.1 is now available on .Vercel AI Gateway This is a beta coding model trained for agentic coding, currently in early access, and powers the Grok Build CLI app. Reasoning effort is not configurable, and there is no non-reasoning mode.",
          "startOffset": 0,
          "endOffset": 245,
          "citation": {
            "title": "Grok Build 0.1 now available on Vercel AI Gateway",
            "source": "Vercel News",
            "url": "https://vercel.com/changelog/grok-build-0-1-now-available-on-vercel-ai-gateway"
          }
        }
      ],
