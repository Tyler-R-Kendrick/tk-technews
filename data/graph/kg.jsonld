      "status": "parsed",
      "title": "Grok Build 0.1 now available on Vercel AI Gateway",
      "sourceName": "Vercel News",
      "sourceKind": "vercelAnnouncements",
      "publishedAt": "2026-05-20T07:00:00.000Z",
