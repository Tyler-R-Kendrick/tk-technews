{
  "name": "tk-technews",
  "version": "0.1.0",
  "private": true,
  "description": "Static Astro AI tech news site with source monitoring, generated briefs, and GitHub Pages deployment.",
  "homepage": "https://tyler-r-kendrick.github.io/tk-technews/",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deps:prepare": "node scripts/ensure-local-runtime-deps.mjs",
    "ingest": "node scripts/ingest.mjs",
    "summaries:weekly": "node scripts/build-weekly-summaries.mjs",
    "precompile:sources": "node scripts/precompile-sources.mjs",
    "scrape:firecrawl": "node scripts/scrape-firecrawl.mjs",
    "mcp:youtube": "node servers/youtube-data-mcp/server.mjs",
    "mcp:youtube-transcript": "node servers/youtube-transcript-mcp/server.mjs",
    "extract:knowledge": "node scripts/extract-knowledge.mjs",
    "graph:persist-weekly": "node scripts/persist-weekly-graph.mjs",
    "draft": "node scripts/draft-article.mjs",
    "source:ingest": "node scripts/source-ingest.mjs",
    "source:brief": "node scripts/source-brief.mjs",
    "source:enrich": "node scripts/source-enrich.mjs",
    "aggregate:brief": "node scripts/aggregate-brief.mjs",
    "article:generate": "node scripts/article-generate.mjs",
    "pipeline:source": "node scripts/pipeline-source.mjs",
    "pipeline:daily": "node scripts/pipeline-daily.mjs",
    "daily:generate": "npm run precompile:sources && node scripts/generate-daily-articles.mjs",
    "daily:agentic": "node scripts/run-daily-source-generation.mjs",
    "wiki:generate": "node scripts/generate-wiki.mjs",
    "pipeline": "npm run precompile:sources && npm run ingest && npm run extract:knowledge && npm run draft",
    "validate:citations": "node scripts/validate-citations.mjs",
    "eval:narrator:validate": "node scripts/agentv-eval-runner.mjs validate",
    "eval:narrator": "node scripts/agentv-eval-runner.mjs run",
    "eval:narrator:fixtures": "node --test scripts/agentv-narrator-provider.test.mjs scripts/lib/narrator-voice-evals.test.mjs scripts/lib/generation-loop.test.mjs",
    "eval:daily-social:validate": "node scripts/agentv-daily-social-eval-runner.mjs validate",
    "eval:daily-social": "node scripts/agentv-daily-social-eval-runner.mjs run",
    "eval:daily-social:sdk": "node --experimental-strip-types --test scripts/agentv-source-grounding-sdk.test.ts",
    "eval:daily-social:fixtures": "node --experimental-strip-types --test scripts/agentv-daily-social-provider.test.mjs scripts/agentv-source-grounding-sdk.test.ts scripts/lib/rich-citations.test.mjs scripts/lib/daily-article-stubs.test.mjs",
    "test:daily": "node --test scripts/package-scripts.test.mjs scripts/ingest.test.mjs scripts/lib/daily-archive.test.mjs scripts/lib/daily-article-stubs.test.mjs scripts/lib/daily-publish-guard.test.mjs scripts/lib/daily-source-generation-runner.test.mjs scripts/lib/precompile-sources.test.mjs scripts/lib/rich-citations.test.mjs src/lib/inline-markdown.test.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@astrojs/check": "^0.9.4",
    "@github/copilot-sdk": "^1.0.0-beta.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.132.0",
    "ai": "^6.0.185",
    "astro": "^6.3.5",
    "cheerio": "^1.2.0",
    "rss-parser": "^3.13.0",
    "typescript": "^5.9.3",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "agentv": "^4.30.0"
  }
}
