---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { citationPreview } from '../../../scripts/lib/rich-citations.mjs';

type ArticleModule = {
  frontmatter: {
    title: string;
    description?: string;
    pubDate?: string;
    sourceCount?: number;
    citations?: Array<{ title: string; url: string; source: string }>;
  };
  default: any;
};

export async function getStaticPaths() {
  const modules = import.meta.glob<ArticleModule>('../../content/articles/*.md', { eager: true });

  return Object.entries(modules).map(([path, article]) => {
    const slug = path.split('/').pop()?.replace('.md', '');
    return {
      params: { slug },
      props: { article }
    };
  });
}

const { article } = Astro.props;
const ArticleContent = article.default;
const citationPreviews = (article.frontmatter.citations ?? []).map(citationPreview);
---

<BaseLayout title={`${article.frontmatter.title} | TK TechNews`} description={article.frontmatter.description}>
  <main class="site-shell article-shell">
    <header class="masthead">
      <a class="brand" href="/">TK TechNews</a>
      <nav aria-label="Primary navigation">
        <a href="/">All drafts</a>
        <a href="/wiki/">Wiki</a>
      </nav>
    </header>

    <article class="article-page">
      <header class="article-hero">
        <p class="article-date">{article.frontmatter.pubDate}</p>
        <h1>{article.frontmatter.title}</h1>
        {article.frontmatter.description && <p>{article.frontmatter.description}</p>}
      </header>

      <div class="article-grid">
        <div class="prose">
          <ArticleContent />
        </div>

        {article.frontmatter.citations && (
          <aside class="citation-rail" aria-label="Citations">
            <h2>Citations</h2>
            <ol class="rich-citation-list">
              {citationPreviews.map((citation) => (
                <li>
                  <a class={`rich-source-preview rich-source-preview-${citation.kind}`} href={citation.href} rel="noreferrer">
                    {citation.thumbnailUrl && <img src={citation.thumbnailUrl} alt="" loading="lazy" />}
                    <span class="rich-source-copy">
                      <span class="rich-source-meta">
                        <span>{citation.label}</span>
                        <span>{citation.source}</span>
                      </span>
                      <strong>{citation.title}</strong>
                      {citation.snippet && <span class="rich-source-snippet">{citation.snippet}</span>}
                      <span class="rich-source-host">{citation.host}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </aside>
        )}
      </div>
    </article>
  </main>
</BaseLayout>
