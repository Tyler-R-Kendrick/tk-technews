---
import BaseLayout from '../layouts/BaseLayout.astro';
import { dailyArchiveSummary, dailyBrief } from '../lib/daily-feed.mjs';

const generatedAt = new Date(dailyBrief.generatedAt).toLocaleString('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short'
});
const displayDate = new Date(`${dailyBrief.date}T12:00:00.000Z`).toLocaleDateString('en-US', {
  dateStyle: 'full'
});
const leadStub = dailyBrief.articleStubs[0];
const remainingStubs = dailyBrief.articleStubs.slice(1);
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, '')}`;
---

<BaseLayout title="TK TechNews" description="Daily AI technology briefings deduplicated from monitored sources.">
  <main class="site-shell">
    <header class="masthead">
      <a class="brand" href={withBase('/')}>TK TechNews</a>
      <nav aria-label="Primary navigation">
        <a href={withBase('/sources/')}>Sources</a>
        <a href={withBase('/daily/')}>Archive</a>
        <a href={withBase('/wiki/')}>Wiki</a>
        <a href={withBase('/articles/last-week-in-ai-2026-05-20/')}>Weekly</a>
      </nav>
    </header>

    <section class="hero daily-hero">
      <div>
        <p class="article-date">{displayDate}</p>
        <h1>Today in AI</h1>
        <p>
          A deduplicated brief built from the day&apos;s monitored videos, feeds,
          research posts, repositories, and social updates. Similar announcements
          are grouped into one article stub with source links ready for expansion.
        </p>
      </div>
      <aside class="process-panel" aria-label="Daily aggregation stats">
        <span>{dailyBrief.sourceItemCount} source items</span>
        <span>{dailyBrief.articleStubs.length} deduped stubs</span>
        <span>Updated {generatedAt}</span>
      </aside>
    </section>

    {leadStub ? (
      <section class="daily-lead" aria-labelledby="lead-heading">
        <p class="article-date">Top consolidated stub</p>
        <h2 id="lead-heading"><a href={withBase(leadStub.href)}>{leadStub.title}</a></h2>
        <p>{leadStub.dek}</p>
        <div class="daily-stub-meta">
          <span>{leadStub.sourceCount} sources</span>
          <span>{leadStub.status}</span>
        </div>
      </section>
    ) : (
      <section class="daily-lead" aria-labelledby="lead-heading">
        <p class="article-date">No source items yet</p>
        <h2 id="lead-heading">Daily brief pending</h2>
        <p>Run the source precompile pipeline to populate today&apos;s deduplicated article stubs.</p>
      </section>
    )}

    <section class="article-list daily-stub-list" aria-labelledby="daily-heading">
      <div class="section-heading">
        <h2 id="daily-heading">Daily Article Stubs</h2>
        <p>Each card consolidates similar monitored source items into one draftable story angle.</p>
      </div>

      <div class="cards">
        {remainingStubs.map((stub) => (
          <article class="article-card">
            <div class="card-meta">
              <time datetime={stub.latestPublishedAt}>{stub.latestPublishedAt?.slice(0, 10)}</time>
              <span>{stub.sourceCount} sources</span>
            </div>
            <h3><a href={withBase(stub.href)}>{stub.title}</a></h3>
            <p>{stub.dek}</p>
            <ul class="tags" aria-label="Tags">
              {stub.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {dailyArchiveSummary.length > 1 && (
      <section class="article-list daily-stub-list" aria-labelledby="archive-heading">
        <div class="section-heading">
          <h2 id="archive-heading">Daily Archive</h2>
          <p>Recent published briefing days remain available even when a new ingest run does not produce a publishable update.</p>
        </div>

        <div class="cards">
          {dailyArchiveSummary.slice(0, 6).map((entry) => (
            <article class="article-card">
              <div class="card-meta">
                <time datetime={entry.date}>{entry.date}</time>
                <span>{entry.articleCount} stubs</span>
              </div>
              <h3>
                {entry.leadSlug ? (
                  <a href={withBase(`/daily/${entry.date}/${entry.leadSlug}/`)}>
                    {entry.leadTitle ?? entry.date}
                  </a>
                ) : (
                  entry.date
                )}
              </h3>
              <p>{entry.sourceItemCount} source items captured for the published brief.</p>
            </article>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
